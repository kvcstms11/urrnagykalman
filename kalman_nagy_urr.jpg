<!DOCTYPE html>
<html lang="hu">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Urr Nagy Kálmán — Angol nyelvoktatás, fordítás, zongoraoktatás</title>
  <meta name="description" content="Urr Nagy Kálmán — angol-magyar nyelvoktatás, szinkrontolmácsolás, fordítás és klasszikus zongoraoktatás. 18 év amerikai tapasztalat.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Source+Sans+3:wght@300;400;600&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg: #06060f;
      --bg-card: #0e0e1a;
      --bg-card-hover: #14142a;
      --text: #d4d0e0;
      --text-dim: #8a86a0;
      --gold: #d4a843;
      --gold-glow: rgba(212, 168, 67, 0.25);
      --accent: #5b8fd4;
      --border: rgba(255,255,255,0.07);
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Source Sans 3', sans-serif;
      color: var(--text);
      background: var(--bg);
      line-height: 1.7;
      font-weight: 300;
      -webkit-font-smoothing: antialiased;
    }

    /* === NAV === */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      background: rgba(6, 6, 15, 0.85);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
    }
    .nav-inner {
      max-width: 1100px; margin: 0 auto;
      padding: 0.7rem 1.5rem;
      display: flex; align-items: center; justify-content: space-between;
    }
    .nav-name {
      font-family: 'Cinzel', serif;
      font-size: 1rem; font-weight: 700;
      color: var(--gold);
      text-decoration: none;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }
    .nav-links { display: flex; gap: 1.6rem; }
    .nav-links a {
      text-decoration: none; color: var(--text-dim);
      font-size: 0.8rem; font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.08em;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--gold); }

    .menu-toggle { display: none; background: none; border: none; cursor: pointer; padding: 0.5rem; }
    .menu-toggle span { display: block; width: 22px; height: 2px; background: var(--text); margin: 5px 0; transition: 0.3s; }

    @media (max-width: 700px) {
      .menu-toggle { display: block; }
      .nav-links {
        display: none; flex-direction: column; gap: 0;
        position: absolute; top: 100%; left: 0; right: 0;
        background: rgba(6,6,15,0.97); border-bottom: 1px solid var(--border);
      }
      .nav-links.open { display: flex; }
      .nav-links a { padding: 0.9rem 1.5rem; border-top: 1px solid var(--border); }
    }

    /* === HERO / SOLAR SYSTEM === */
    .hero {
      position: relative;
      width: 100%;
      padding-top: 3.2rem;
      overflow: hidden;
      background: var(--bg);
    }
    .hero-img-wrap {
      position: relative;
      width: 100%;
    }
    .hero-img-wrap img {
      display: block;
      width: 100%;
      height: auto;
    }

    /* planet hotspots */
    .planet {
      position: absolute;
      border-radius: 50%;
      cursor: pointer;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      z-index: 2;
      text-decoration: none;
    }
    .planet::before {
      content: '';
      position: absolute;
      inset: -6px;
      border-radius: 50%;
      border: 1.5px solid transparent;
      transition: border-color 0.3s, box-shadow 0.3s;
    }
    .planet:hover {
      transform: scale(1.15);
    }
    .planet:hover::before {
      border-color: var(--gold);
      box-shadow: 0 0 24px var(--gold-glow), 0 0 60px rgba(212,168,67,0.1);
    }

    /* tooltip */
    .planet .tip {
      position: absolute;
      bottom: calc(100% + 12px);
      left: 50%;
      transform: translateX(-50%) translateY(6px);
      background: rgba(6,6,15,0.94);
      border: 1px solid var(--gold);
      color: var(--gold);
      font-family: 'Cinzel', serif;
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.3rem 0.65rem;
      border-radius: 3px;
      white-space: nowrap;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.25s, transform 0.25s;
    }
    .planet .tip::after {
      content: '';
      position: absolute;
      top: 100%;
      left: 50%;
      transform: translateX(-50%);
      border: 5px solid transparent;
      border-top-color: var(--gold);
    }
    .planet:hover .tip {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }

    /* Pulse animation */
    @keyframes pulse-ring {
      0% { box-shadow: 0 0 0 0 rgba(212,168,67,0.3); }
      70% { box-shadow: 0 0 0 8px rgba(212,168,67,0); }
      100% { box-shadow: 0 0 0 0 rgba(212,168,67,0); }
    }
    .planet { animation: pulse-ring 3.5s ease-out infinite; }
    .planet:nth-child(2) { animation-delay: 0.35s; }
    .planet:nth-child(3) { animation-delay: 0.7s; }
    .planet:nth-child(4) { animation-delay: 1.05s; }
    .planet:nth-child(5) { animation-delay: 1.4s; }
    .planet:nth-child(6) { animation-delay: 1.75s; }
    .planet:nth-child(7) { animation-delay: 2.1s; }
    .planet:nth-child(8) { animation-delay: 2.45s; }
    .planet:nth-child(9) { animation-delay: 2.8s; }
    .planet:nth-child(10) { animation-delay: 3.15s; }

    /* hero overlay text */
    .hero-overlay {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      padding: 3.5rem 1.5rem 1.5rem;
      background: linear-gradient(to top, var(--bg) 0%, rgba(6,6,15,0.75) 55%, transparent 100%);
      text-align: center;
    }
    .hero-overlay h1 {
      font-family: 'Cinzel', serif;
      font-size: clamp(1.3rem, 4vw, 2.2rem);
      font-weight: 700;
      color: #fff;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      text-shadow: 0 2px 20px rgba(0,0,0,0.6);
    }
    .hero-overlay h1 span { color: var(--gold); }
    .hero-overlay .hero-sub {
      margin-top: 0.3rem;
      font-size: 0.85rem;
      color: var(--text-dim);
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }
    .hero-hint {
      margin-top: 0.7rem;
      font-size: 0.72rem;
      color: rgba(212,168,67,0.45);
      letter-spacing: 0.04em;
    }

    @media (max-width: 600px) {
      .planet .tip { font-size: 0.58rem; padding: 0.2rem 0.4rem; bottom: calc(100% + 8px); }
      .hero-hint { display: none; }
    }

    /* === SECTIONS === */
    section { padding: 4.5rem 1.5rem; }
    .container { max-width: 960px; margin: 0 auto; }

    .section-title {
      font-family: 'Cinzel', serif;
      font-size: 1.5rem; font-weight: 700;
      letter-spacing: 0.06em;
      color: #fff;
    }
    .section-line {
      width: 50px; height: 2px;
      background: var(--gold);
      margin: 0.6rem 0 2rem;
    }

    /* === INTRO === */
    .intro-grid {
      display: grid; grid-template-columns: 200px 1fr; gap: 2.5rem;
      align-items: start;
    }
    .intro-portrait {
      width: 200px; height: 240px;
      object-fit: cover; object-position: top center;
      border-radius: 4px;
      border: 2px solid rgba(212,168,67,0.2);
    }
    .intro-text p { margin-bottom: 1rem; font-size: 1rem; }
    .highlight-box {
      background: var(--bg-card);
      border-left: 3px solid var(--gold);
      padding: 1rem 1.3rem;
      border-radius: 0 4px 4px 0;
      margin-top: 0.5rem;
      font-size: 0.95rem;
    }
    .highlight-box strong { color: var(--gold); }

    @media (max-width: 640px) {
      .intro-grid { grid-template-columns: 1fr; text-align: center; }
      .intro-portrait { margin: 0 auto; width: 170px; height: 210px; }
    }

    /* === SERVICES === */
    .services-section { background: var(--bg-card); }
    .services-grid {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;
    }
    .service-card {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 1.8rem 1.4rem;
      transition: border-color 0.3s, transform 0.2s;
    }
    .service-card:hover {
      border-color: rgba(212,168,67,0.25);
      transform: translateY(-3px);
    }
    .service-icon { font-size: 1.8rem; margin-bottom: 0.7rem; display: block; }
    .service-card h3 {
      font-family: 'Cinzel', serif;
      font-size: 1rem; margin-bottom: 0.4rem;
      color: var(--gold);
      letter-spacing: 0.04em;
    }
    .service-card p { font-size: 0.9rem; color: var(--text-dim); }

    @media (max-width: 700px) {
      .services-grid { grid-template-columns: 1fr; }
    }

    /* === DOCUMENTS === */
    .docs-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(270px, 1fr)); gap: 0.7rem;
    }
    .doc-card {
      display: flex; align-items: center; gap: 0.8rem;
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 5px;
      padding: 0.7rem 1rem;
      text-decoration: none;
      color: var(--text);
      transition: border-color 0.2s, background 0.2s;
    }
    .doc-card:hover {
      border-color: rgba(212,168,67,0.25);
      background: var(--bg-card-hover);
    }
    .doc-icon {
      width: 34px; height: 34px; flex-shrink: 0;
      background: rgba(212,168,67,0.1);
      border: 1px solid rgba(212,168,67,0.18);
      border-radius: 5px;
      display: flex; align-items: center; justify-content: center;
    }
    .doc-icon svg { width: 16px; height: 16px; fill: var(--gold); }
    .doc-icon.alt { background: rgba(91,143,212,0.1); border-color: rgba(91,143,212,0.18); }
    .doc-icon.alt svg { fill: var(--accent); }
    .doc-info { min-width: 0; }
    .doc-title {
      font-weight: 600; font-size: 0.85rem; line-height: 1.3; color: var(--text);
      display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
    }
    .doc-meta { font-size: 0.7rem; color: var(--text-dim); margin-top: 0.1rem; }

    /* === CONTACT === */
    .contact-section {
      background: linear-gradient(to bottom, var(--bg-card) 0%, var(--bg) 100%);
    }
    .contact-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem;
    }
    .contact-grid p { color: var(--text-dim); margin-bottom: 0.8rem; }
    .contact-item { display: flex; align-items: center; gap: 0.8rem; margin-bottom: 1rem; }
    .ci-icon {
      width: 36px; height: 36px; flex-shrink: 0;
      background: rgba(212,168,67,0.08);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
    }
    .ci-icon svg { width: 16px; height: 16px; fill: var(--gold); }
    .ci-text { font-size: 1rem; color: var(--text); }
    .ci-label { font-size: 0.72rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.06em; }

    @media (max-width: 700px) {
      .contact-grid { grid-template-columns: 1fr; }
    }

    /* === FOOTER === */
    footer {
      text-align: center; padding: 1.5rem;
      font-size: 0.75rem; color: var(--text-dim);
      border-top: 1px solid var(--border);
    }

    /* === FADE-IN === */
    .fade-in {
      opacity: 0; transform: translateY(18px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .fade-in.visible { opacity: 1; transform: translateY(0); }
  </style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-inner">
    <a href="#" class="nav-name">Urr Nagy Kálmán</a>
    <button class="menu-toggle" aria-label="Menü" onclick="document.querySelector('.nav-links').classList.toggle('open')">
      <span></span><span></span><span></span>
    </button>
    <div class="nav-links">
      <a href="#rolam">Rólam</a>
      <a href="#szolgaltatasok">Szolgáltatások</a>
      <a href="#dokumentumok">Dokumentumok</a>
      <a href="#kapcsolat">Kapcsolat</a>
    </div>
  </div>
</nav>

<!-- HERO — SOLAR SYSTEM -->
<header class="hero">
  <div class="hero-img-wrap">
    <img src="header.jpg" alt="Naprendszer" id="hero-img">

    <!-- Clickable planet hotspots — % positions over the image -->
    <a href="#rolam" class="planet" style="left:3%; top:10%; width:7%; height:62%;">
      <span class="tip">Nap — Bemutatkozás</span>
    </a>
    <a href="#szolgaltatasok" class="planet" style="left:13.2%; top:38%; width:2.4%; height:10%;">
      <span class="tip">Merkúr — Nyelvoktatás</span>
    </a>
    <a href="#szolgaltatasok" class="planet" style="left:17.2%; top:31%; width:3%; height:14%;">
      <span class="tip">Vénusz — Fordítás</span>
    </a>
    <a href="#rolam" class="planet" style="left:21.5%; top:33%; width:3.2%; height:14%;">
      <span class="tip">Föld — Rólam</span>
    </a>
    <a href="#szolgaltatasok" class="planet" style="left:26.8%; top:38%; width:2.4%; height:10%;">
      <span class="tip">Mars — Zongora</span>
    </a>
    <a href="#dokumentumok" class="planet" style="left:34%; top:20%; width:7.5%; height:32%;">
      <span class="tip">Jupiter — Egyetemes Jogok</span>
    </a>
    <a href="#dokumentumok" class="planet" style="left:47%; top:24%; width:9.5%; height:28%;">
      <span class="tip">Szaturnusz — Dokumentumok</span>
    </a>
    <a href="#kapcsolat" class="planet" style="left:63%; top:34%; width:4%; height:16%;">
      <span class="tip">Uránusz — Kapcsolat</span>
    </a>
    <a href="#dokumentumok" class="planet" style="left:72%; top:35%; width:3.5%; height:14%;">
      <span class="tip">Neptunusz — Kiadványok</span>
    </a>
    <a href="#kapcsolat" class="planet" style="left:80.5%; top:40%; width:2%; height:8%;">
      <span class="tip">Plútó — Elérhetőség</span>
    </a>

    <div class="hero-overlay">
      <h1>Urr Nagy <span>Kálmán</span></h1>
      <p class="hero-sub">Angol nyelvoktatás · Fordítás · Klasszikus zongora</p>
      <div class="hero-hint">&#9650; Kattints egy bolygóra a navigáláshoz &#9650;</div>
    </div>
  </div>
</header>

<!-- RÓLAM -->
<section id="rolam">
  <div class="container">
    <h2 class="section-title fade-in">Rólam</h2>
    <div class="section-line fade-in"></div>
    <div class="intro-grid">
      <img src="kalman_nagy_urr.jpg" alt="Urr Nagy Kálmán" class="intro-portrait fade-in">
      <div class="intro-text fade-in">
        <p>Urr Nagy Kálmán vagyok. 18 évig éltem az Egyesült Államokban, így az angol nyelvtudásom anyanyelvi szintű. A szókincsem mintegy 320 000 szót, kifejezést és szófordulatot ölel fel.</p>
        <p>Teljesen folyékonyan beszélek angolul és magyarul. Bármilyen szöveget képes vagyok szinkronban tolmácsolni mindkét nyelven, és fordítást is vállalok mindkét irányban.</p>
        <p>Szakterületeim: jog, kereskedelem, üzleti élet, emberi jogok, diplomácia, képzőművészet, tudomány, történelem, politika, vallás és katonai ügyek.</p>
        <div class="highlight-box">
          <strong>Helyszínek:</strong> Nagykanizsa, Keszthely, Zalaegerszeg<br>
          <strong>Nyelvek:</strong> Angol (anyanyelvi szint), Magyar<br>
          <strong>Tapasztalat:</strong> 18 év az USA-ban
        </div>
      </div>
    </div>
  </div>
</section>

<!-- SZOLGÁLTATÁSOK -->
<section id="szolgaltatasok" class="services-section">
  <div class="container">
    <h2 class="section-title fade-in">Szolgáltatások</h2>
    <div class="section-line fade-in"></div>
    <div class="services-grid">
      <div class="service-card fade-in">
        <span class="service-icon">🌐</span>
        <h3>Angol nyelvoktatás</h3>
        <p>Egyéni és csoportos (max. 3–4 fő) angol–magyar és magyar–angol nyelvoktatás alap szinttől az anyanyelvi szintig. Nyelvvizsgára felkészítés bármilyen fokon.</p>
      </div>
      <div class="service-card fade-in">
        <span class="service-icon">📝</span>
        <h3>Fordítás és tolmácsolás</h3>
        <p>Szinkrontolmácsolás, szakfordítás angol–magyar irányban: jogi, gazdasági, műszaki, orvosi, irodalmi, tudományos és EU-s szövegek. Akár napi 25 oldal.</p>
      </div>
      <div class="service-card fade-in">
        <span class="service-icon">🎹</span>
        <h3>Klasszikus zongoraoktatás</h3>
        <p>Színvonalas klasszikus zongoraoktatás egyéni formában, minden szinten. A zenei képzés párhuzamosan is folytatható a nyelvtanulással.</p>
      </div>
    </div>
  </div>
</section>

<!-- DOKUMENTUMOK -->
<section id="dokumentumok">
  <div class="container">
    <h2 class="section-title fade-in">Dokumentumok és kiadványok</h2>
    <div class="section-line fade-in"></div>
    <p class="fade-in" style="margin-bottom: 1.5rem; color: var(--text-dim);">Az alábbi PDF dokumentumok szabadon letölthetők.</p>

    <h3 class="fade-in" style="font-family:'Cinzel',serif; font-size:0.95rem; margin-bottom:0.8rem; color:var(--gold); letter-spacing:0.06em;">Egyetemes Jogok sorozat</h3>
    <div class="docs-grid fade-in" style="margin-bottom: 2rem;">
      <a class="doc-card" href="pdfs/01-egy-gonosz-birodalom.pdf" target="_blank"><div class="doc-icon"><svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm-1 1.5L18.5 9H13V3.5zM6 20V4h5v7h7v9H6z"/></svg></div><div class="doc-info"><div class="doc-title">1. Egy gonosz birodalom</div><div class="doc-meta">PDF · 2013</div></div></a>
      <a class="doc-card" href="pdfs/02-teremtes-II.pdf" target="_blank"><div class="doc-icon"><svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm-1 1.5L18.5 9H13V3.5zM6 20V4h5v7h7v9H6z"/></svg></div><div class="doc-info"><div class="doc-title">2. Teremtés II</div><div class="doc-meta">PDF · 2013</div></div></a>
      <a class="doc-card" href="pdfs/03-egyesult-magyarorszag-alkotmanya.pdf" target="_blank"><div class="doc-icon"><svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm-1 1.5L18.5 9H13V3.5zM6 20V4h5v7h7v9H6z"/></svg></div><div class="doc-info"><div class="doc-title">3. Egyesült Magyarország Alkotmánya</div><div class="doc-meta">PDF · 2013</div></div></a>
      <a class="doc-card" href="pdfs/04-egyesult-europa-alkotmanya.pdf" target="_blank"><div class="doc-icon"><svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm-1 1.5L18.5 9H13V3.5zM6 20V4h5v7h7v9H6z"/></svg></div><div class="doc-info"><div class="doc-title">4. Egyesült Európa Alkotmánya</div><div class="doc-meta">PDF · 2013</div></div></a>
      <a class="doc-card" href="pdfs/05-egyesult-amerika-alkotmanya.pdf" target="_blank"><div class="doc-icon"><svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm-1 1.5L18.5 9H13V3.5zM6 20V4h5v7h7v9H6z"/></svg></div><div class="doc-info"><div class="doc-title">5. Egyesült Amerika Alkotmánya</div><div class="doc-meta">PDF · 2013</div></div></a>
      <a class="doc-card" href="pdfs/06-egyesult-azsia-alkotmanya.pdf" target="_blank"><div class="doc-icon"><svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm-1 1.5L18.5 9H13V3.5zM6 20V4h5v7h7v9H6z"/></svg></div><div class="doc-info"><div class="doc-title">6. Egyesült Ázsia Alkotmánya</div><div class="doc-meta">PDF · 2013</div></div></a>
      <a class="doc-card" href="pdfs/07-egyesult-ausztralia-alkotmanya.pdf" target="_blank"><div class="doc-icon"><svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm-1 1.5L18.5 9H13V3.5zM6 20V4h5v7h7v9H6z"/></svg></div><div class="doc-info"><div class="doc-title">7. Egyesült Ausztrália Alkotmánya</div><div class="doc-meta">PDF · 2013</div></div></a>
